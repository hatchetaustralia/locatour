{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "autoIncrement": true,
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://locatour-production-acllqt.laravel.cloud",
        "EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID": "497605846776-r399oopeutqlvf3fpt117774v49m0odm.apps.googleusercontent.com"
      }
    },
    "production": {
      "channel": "production",
      "autoIncrement": true,
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://locatour-production-acllqt.laravel.cloud",
        "EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID": "497605846776-r399oopeutqlvf3fpt117774v49m0odm.apps.googleusercontent.com",
        "EXPO_ANDROID_ABIS": "armeabi-v7a,arm64-v8a,x86,x86_64"
      }
    }
  },
  "submit": {
    "production": {
      "android": {
        "serviceAccountKeyPath": "./google-service-account.json",
        "track": "internal",
        "releaseStatus": "draft"
      }
    }
  }
}
