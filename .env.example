# Locatour app config — values prefixed EXPO_PUBLIC_ are inlined into the client
# bundle by Expo at build time (see src/constants/config.ts).
# Copy this file to `.env` and fill in your own values.

# Base URL of the Laravel API (no trailing slash). Defaults to the Herd domain.
#
# Physical device: localhost won't reach your Mac — use your Mac's LAN IP
#   (find it with `ipconfig getifaddr en0`), e.g. http://192.168.20.10:8000,
#   or the Herd domain reachable on your network, e.g. http://locatour-api.test
# iOS Simulator: http://localhost:8000
# Android emulator: http://10.0.2.2:8000
EXPO_PUBLIC_API_URL=http://localhost:8000
