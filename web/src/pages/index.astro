---
// src/pages/index.astro
import '../styles/global.css';

const title       = 'Locatour — Turn the outdoors into a game';
const description = 'A real-world exploration game for public places. Open the map, walk to real parks, lookouts and hidden spots, check in with a photo, earn points and level up.';
const canonicalURL = 'https://locatour.com.au/';
const ogImage      = 'https://locatour.com.au/og-image.png';

// Greyed "coming soon" store badges — custom placeholder art, not the official
// store badge artwork, so they clearly read as "not live yet".
const storeBadges = `
  <div class="store-badges" role="group" aria-label="App stores — coming soon">
    <span class="store-badge" aria-disabled="true" aria-label="Coming soon to Google Play">
      <svg class="store-glyph" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M3.61 1.814C3.2 2.054 3 2.5 3 3.054v17.892c0 .554.2 1 .61 1.24l.066.038 10.02-10.02v-.236L3.676 1.776l-.066.038zM17.44 15.17l-3.34-3.34v-.236l3.34-3.34.076.044 3.956 2.248c1.13.642 1.13 1.69 0 2.332L17.516 15.13l-.076.04zM3.676 22.186L14.354 11.51 11.01 8.166 3.676 22.186zM14.354 12.49L3.676 1.814l7.334 14.02 3.344-3.344z"/>
      </svg>
      <span class="store-badge-copy"><small>Coming soon to</small><strong>Google Play</strong></span>
    </span>
    <span class="store-badge" aria-disabled="true" aria-label="Coming soon to the App Store">
      <svg class="store-glyph" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M17.05 12.04c-.03-2.6 2.12-3.85 2.22-3.91-1.21-1.77-3.1-2.01-3.77-2.04-1.6-.16-3.13.94-3.94.94-.81 0-2.07-.92-3.4-.89-1.75.03-3.36 1.02-4.26 2.58-1.82 3.16-.47 7.83 1.31 10.39.87 1.25 1.9 2.66 3.26 2.61 1.31-.05 1.8-.85 3.39-.85 1.58 0 2.03.85 3.41.82 1.41-.02 2.3-1.28 3.16-2.54.99-1.45 1.4-2.86 1.42-2.93-.03-.01-2.73-1.05-2.76-4.16zM14.46 4.5c.72-.87 1.2-2.08 1.07-3.29-1.03.04-2.28.69-3.02 1.56-.66.77-1.24 2-1.08 3.18 1.15.09 2.32-.58 3.03-1.45z"/>
      </svg>
      <span class="store-badge-copy"><small>Coming soon to</small><strong>App Store</strong></span>
    </span>
  </div>
`;
---

<!doctype html>
<html lang="en-AU">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />

  <!-- Open Graph -->
  <meta property="og:type"        content="website" />
  <meta property="og:url"         content={canonicalURL} />
  <meta property="og:title"       content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image"       content={ogImage} />
  <meta property="og:locale"      content="en_AU" />

  <!-- Twitter -->
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image"       content={ogImage} />

  <!-- Fonts: rounded + friendly -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Fredoka:wght@500;600;700&family=Nunito:wght@400;600;700;800&display=swap" />

  <!-- JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Organization",
        "name": "Locatour",
        "url": "https://locatour.com.au",
        "logo": "https://locatour.com.au/app-icon.png",
        "description": "A real-world exploration game for public outdoor places.",
        "email": "support@hatchet.com.au"
      },
      {
        "@type": "MobileApplication",
        "name": "Locatour",
        "applicationCategory": "GameApplication",
        "operatingSystem": "Android",
        "description": "Visit public outdoor places, check in with a photo, earn points, and explore further.",
        "offers": { "@type": "Offer", "price": "0", "priceCurrency": "AUD" }
      }
    ]
  })} />

  <link rel="icon"    type="image/svg+xml" href="/favicon.svg" />
  <link rel="sitemap" href="/sitemap-index.xml" />
</head>
<body>

  <!-- ── Header ── -->
  <header class="site-header">
    <div class="container header-inner">
      <a href="/" class="logo-link" aria-label="Locatour home">
        <img class="logo-mark" src="/app-icon.png" alt="" width="40" height="40" aria-hidden="true" />
        <span class="logo-name">Locatour</span>
      </a>
      <nav aria-label="Main navigation">
        <ul class="nav-list">
          <li><a href="#how" class="nav-link">How it works</a></li>
          <li><a href="#peek" class="nav-link">Screenshots</a></li>
          <li>
            <a href="https://docs.locatour.com.au" class="nav-link" target="_blank" rel="noopener noreferrer">Docs</a>
          </li>
          <li><a href="#get" class="nav-link nav-cta">Get the app</a></li>
        </ul>
      </nav>
    </div>
  </header>

  <!-- ── Hero ── -->
  <section class="hero" aria-labelledby="hero-title">
    <div class="hero-bg" aria-hidden="true">
      <div class="blob blob-1"></div>
      <div class="blob blob-2"></div>
      <div class="blob blob-3"></div>
    </div>

    <div class="container hero-inner">
      <div class="hero-copy">
        <span class="eyebrow">🧭 Real-world adventure game</span>
        <h1 class="hero-title" id="hero-title">
          Go outside.<br /><span class="hl">Level up.</span>
        </h1>
        <p class="hero-subhead">
          Locatour turns the map around you into a game. Walk to real parks, lookouts
          and hidden spots, check in with a photo, and earn your way across the world —
          one place at a time.
        </p>

        <div id="get" set:html={storeBadges}></div>

        <div class="hero-actions">
          <a href="#how" class="btn btn-ghost">See how it works ↓</a>
        </div>
        <p class="hero-note">Free to play · Android first · iOS soon</p>
      </div>

      <div class="hero-art" aria-hidden="true">
        <div class="phone phone-hero">
          <img src="/phone/01-map.png" alt="" width="484" height="1050" loading="eager" />
        </div>
        <!-- floating game chips -->
        <span class="float-chip chip-a">🏆 +100</span>
        <span class="float-chip chip-b">🏆 +1300</span>
        <img class="float-sticker sticker-coin" src="/stickers/coin-teal.png" alt="" width="120" height="130" />
        <img class="float-sticker sticker-hiking" src="/stickers/hiking.png" alt="" width="120" height="122" />
      </div>
    </div>
  </section>

  <!-- ── How it works ── -->
  <section class="how" id="how" aria-labelledby="how-title">
    <div class="container">
      <header class="section-header">
        <span class="eyebrow eyebrow-center">How it works</span>
        <h2 class="section-title" id="how-title">Four steps. A whole world to find.</h2>
      </header>

      <ol class="steps" role="list">
        <li class="step-card">
          <div class="step-num">1</div>
          <img class="step-sticker" src="/stickers/boot.png" alt="" width="120" height="130" loading="eager" />
          <h3 class="step-title">Open the map</h3>
          <p class="step-desc">Real parks, beaches, lookouts and hidden spots appear around you — every one a place you can actually go.</p>
        </li>
        <li class="step-card">
          <div class="step-num">2</div>
          <img class="step-sticker" src="/stickers/camera.png" alt="" width="146" height="107" loading="eager" />
          <h3 class="step-title">Check in with a photo</h3>
          <p class="step-desc">Get there for real, then snap a photo to claim the spot. No faking it — you have to be standing in it.</p>
        </li>
        <li class="step-card">
          <div class="step-num">3</div>
          <img class="step-sticker" src="/stickers/coin-teal.png" alt="" width="120" height="130" loading="eager" />
          <h3 class="step-title">Earn points</h3>
          <p class="step-desc">Every genuine visit banks points. Rarer, harder-to-reach places are worth a whole lot more.</p>
        </li>
        <li class="step-card">
          <div class="step-num">4</div>
          <img class="step-sticker" src="/stickers/hat.png" alt="" width="125" height="120" loading="eager" />
          <h3 class="step-title">Level up</h3>
          <p class="step-desc">Climb the ranks and unlock remote spots saved for the most dedicated explorers. The best views are earned.</p>
        </li>
      </ol>
    </div>
  </section>

  <!-- ── Spotlight: Discover ── -->
  <section class="spotlight spotlight-mint" aria-labelledby="sp1-title">
    <div class="container spotlight-inner">
      <div class="spotlight-art">
        <div class="phone"><img src="/phone/02-discover.png" alt="A list of nearby spots to discover in the Locatour app" width="484" height="1050" loading="eager" /></div>
      </div>
      <div class="spotlight-copy">
        <span class="eyebrow">Discover</span>
        <h2 class="section-title" id="sp1-title">Spots you'd never have found</h2>
        <p>Locatour surfaces the places hiding in plain sight near you — the little lookout, the reserve at the end of the road, the beach nobody posts about. Pull up the list, pick one, and go.</p>
        <ul class="ticks">
          <li>Real public places, free to visit</li>
          <li>Sorted by what's close and worth the most</li>
          <li>Nearby alerts when you're near somewhere new (opt-in)</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- ── Spotlight: Achievements ── -->
  <section class="spotlight spotlight-amber" aria-labelledby="sp2-title">
    <div class="container spotlight-inner spotlight-reverse">
      <div class="spotlight-art">
        <div class="phone"><img src="/phone/05-achievements.png" alt="The achievements screen in the Locatour app" width="484" height="1050" loading="eager" /></div>
      </div>
      <div class="spotlight-copy">
        <span class="eyebrow">Collect &amp; climb</span>
        <h2 class="section-title" id="sp2-title">92 achievements to chase</h2>
        <p>First check-in, off the beaten path, dawn patrol, a clean sweep of a whole region — there's always one more badge just out of reach. Build a streak, fill out your map, and watch your level tick up.</p>
        <ul class="ticks">
          <li>Badges for milestones, streaks and rare finds</li>
          <li>A profile that tells the story of where you've been</li>
          <li>Every check-in counts toward the next level</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- ── Peek inside (gallery) ── -->
  <section class="peek" id="peek" aria-labelledby="peek-title">
    <div class="container">
      <header class="section-header">
        <span class="eyebrow eyebrow-center">Peek inside</span>
        <h2 class="section-title" id="peek-title">A real game, played outside</h2>
      </header>
    </div>
    <div class="gallery" role="list">
      <figure class="gallery-item" role="listitem">
        <div class="phone"><img src="/phone/01-map.png" alt="The live map" width="484" height="1050" loading="eager" /></div>
        <figcaption>The live map</figcaption>
      </figure>
      <figure class="gallery-item" role="listitem">
        <div class="phone"><img src="/phone/02-discover.png" alt="Discover nearby spots" width="484" height="1050" loading="eager" /></div>
        <figcaption>Discover nearby</figcaption>
      </figure>
      <figure class="gallery-item" role="listitem">
        <div class="phone"><img src="/phone/03-checkin.png" alt="Photo check-in" width="484" height="1050" loading="eager" /></div>
        <figcaption>Photo check-in</figcaption>
      </figure>
      <figure class="gallery-item" role="listitem">
        <div class="phone"><img src="/phone/04-levelup.png" alt="Level up" width="484" height="1050" loading="eager" /></div>
        <figcaption>Level up</figcaption>
      </figure>
      <figure class="gallery-item" role="listitem">
        <div class="phone"><img src="/phone/05-achievements.png" alt="Achievements" width="484" height="1050" loading="eager" /></div>
        <figcaption>Achievements</figcaption>
      </figure>
      <figure class="gallery-item" role="listitem">
        <div class="phone"><img src="/phone/06-history.png" alt="Your journey" width="484" height="1050" loading="eager" /></div>
        <figcaption>Your journey</figcaption>
      </figure>
    </div>
  </section>

  <!-- ── Mission ── -->
  <section class="mission" aria-labelledby="mission-title">
    <div class="container mission-inner">
      <div class="mission-text">
        <span class="eyebrow">Why we built it</span>
        <h2 class="section-title" id="mission-title">Public places,<br />owned by everyone</h2>
        <p>
          Australia's parks, reserves, beaches and wild places belong to all of us.
          Locatour is built on a simple idea: the best way to care for a place is to
          help people fall in love with it.
        </p>
        <p>
          Every location in the game is genuine public land — non-commercial, free to
          visit, and already yours. The points are just the scoreboard. The real reward
          is being somewhere you'd never have gone otherwise.
        </p>
      </div>
      <blockquote class="mission-pull">
        A reason to go. A nudge toward the door. A scoreboard for a life spent a little more outside.
      </blockquote>
    </div>
  </section>

  <!-- ── Final CTA ── -->
  <section class="cta" aria-labelledby="cta-title">
    <div class="container cta-inner">
      <img class="cta-icon" src="/app-icon.png" alt="" width="76" height="76" />
      <h2 class="cta-title" id="cta-title">Ready to go outside?</h2>
      <p class="cta-sub">Locatour is launching soon. Get it the day it lands.</p>
      <div set:html={storeBadges}></div>
      <p class="hero-note">Free to play · Android first · iOS soon</p>
    </div>
  </section>

  <!-- ── Footer ── -->
  <footer class="site-footer">
    <div class="container footer-inner">
      <div class="footer-top">
        <a href="/" class="footer-logo" aria-label="Locatour home">
          <img src="/app-icon.png" alt="" width="28" height="28" aria-hidden="true" />
          <span>Locatour</span>
        </a>
        <nav aria-label="Footer navigation">
          <ul class="footer-links">
            <li><a href="https://docs.locatour.com.au/legal/privacy/"  target="_blank" rel="noopener noreferrer">Privacy</a></li>
            <li><a href="https://docs.locatour.com.au/legal/terms/"    target="_blank" rel="noopener noreferrer">Terms</a></li>
            <li><a href="https://docs.locatour.com.au"                 target="_blank" rel="noopener noreferrer">Docs</a></li>
            <li><a href="mailto:support@hatchet.com.au">support@hatchet.com.au</a></li>
          </ul>
        </nav>
      </div>
      <p class="footer-copy">&copy; 2026 Hatchet Pty Ltd</p>
    </div>
  </footer>

</body>
</html>

<style>
/* ── Base type ── */
h1, h2, h3 { font-family: var(--font-display); }

/* ── Header ── */
.site-header {
  position: sticky;
  top: 0;
  z-index: 100;
  background: rgba(252, 240, 232, 0.88);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-bottom: 1px solid var(--color-border);
}
.header-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1.5rem;
  padding-block: 0.7rem;
}
.logo-link { display: flex; align-items: center; gap: 0.55rem; }
.logo-mark {
  width: 40px; height: 40px; border-radius: 11px;
  box-shadow: 0 2px 8px rgba(42,26,20,0.14);
}
.logo-name {
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 1.3rem;
  letter-spacing: -0.01em;
  color: var(--color-ink);
}
.nav-list { display: flex; align-items: center; gap: 0.25rem; }
.nav-link {
  display: inline-flex; align-items: center;
  padding: 0.45rem 0.8rem;
  border-radius: var(--radius-full);
  font-size: 0.95rem; font-weight: 700;
  color: var(--color-ink-muted);
  transition: color 0.15s ease, background 0.15s ease;
}
.nav-link:hover { color: var(--color-ink); background: rgba(42,26,20,0.06); }
.nav-cta {
  background: var(--color-accent); color: #fff;
  box-shadow: 0 4px 0 var(--color-accent-dark);
}
.nav-cta:hover { background: var(--color-accent); color: #fff; transform: translateY(1px); box-shadow: 0 3px 0 var(--color-accent-dark); }

/* ── Shared bits ── */
.eyebrow {
  display: inline-block;
  padding: 0.35rem 0.9rem;
  border-radius: var(--radius-full);
  background: var(--color-accent-pale);
  color: var(--color-accent-dark);
  font-weight: 800;
  font-size: 0.82rem;
  letter-spacing: 0.01em;
}
.eyebrow-center { margin-inline: auto; }
.section-header { text-align: center; margin-bottom: clamp(2rem, 5vw, 3.25rem); display: flex; flex-direction: column; gap: 0.85rem; align-items: center; }
.section-title {
  font-weight: 700;
  font-size: clamp(1.9rem, 4.5vw, 3rem);
  letter-spacing: -0.02em;
  line-height: 1.05;
  color: var(--color-ink);
}

/* ── Buttons ── */
.btn {
  display: inline-flex; align-items: center; gap: 0.45em;
  padding: 0.8rem 1.4rem;
  border-radius: var(--radius-full);
  font-family: var(--font-display);
  font-size: 1rem; font-weight: 600; line-height: 1;
  transition: transform 0.15s ease, box-shadow 0.15s ease;
}
.btn-ghost { color: var(--color-accent-dark); font-weight: 700; font-family: var(--font-sans); }
.btn-ghost:hover { transform: translateY(-1px); }

/* ── Hero ── */
.hero { position: relative; overflow: hidden; padding-block: clamp(2.5rem, 6vw, 4.5rem) clamp(3rem, 8vw, 5.5rem); }
.hero-bg { position: absolute; inset: 0; pointer-events: none; }
.blob { position: absolute; border-radius: 50%; filter: blur(70px); opacity: 0.5; }
.blob-1 { width: 460px; height: 460px; background: var(--color-accent-pale); top: -12%; right: -6%; }
.blob-2 { width: 380px; height: 380px; background: var(--color-mint-pale); bottom: -16%; left: -8%; }
.blob-3 { width: 320px; height: 320px; background: var(--color-amber-pale); top: 30%; left: 30%; opacity: 0.4; }

.hero-inner {
  position: relative; z-index: 1;
  display: grid; grid-template-columns: 1fr; gap: 2.5rem; align-items: center;
}
@media (min-width: 880px) {
  .hero-inner { grid-template-columns: 1.05fr 0.95fr; gap: 1rem; }
}
.hero-copy { display: flex; flex-direction: column; gap: 1.1rem; align-items: flex-start; }
.hero-title {
  font-weight: 700;
  font-size: clamp(2.8rem, 8vw, 5rem);
  line-height: 0.98;
  letter-spacing: -0.03em;
  color: var(--color-ink);
  margin-block: 0.2rem;
}
.hero-title .hl {
  background: linear-gradient(100deg, var(--color-brand-red) 5%, var(--color-accent) 55%, var(--color-mint) 100%);
  -webkit-background-clip: text; background-clip: text; color: transparent;
}
.hero-subhead { max-width: 46ch; font-size: clamp(1.05rem, 2vw, 1.2rem); color: var(--color-ink-muted); line-height: 1.55; }
.hero-actions { margin-top: 0.2rem; }
.hero-note { font-size: 0.85rem; font-weight: 700; color: var(--color-ink-faint); }

/* Hero art / phone */
.hero-art { position: relative; display: flex; justify-content: center; }
.phone {
  position: relative;
  width: 100%; max-width: 300px;
  border-radius: 38px;
  border: 7px solid #1e1218;
  background: #1e1218;
  overflow: hidden;
  box-shadow: var(--shadow-pop);
}
.phone img { display: block; width: 100%; height: auto; border-radius: 30px; }
.phone-hero { max-width: 320px; transform: rotate(-3deg); }

.float-chip {
  position: absolute;
  font-family: var(--font-display); font-weight: 600;
  background: var(--color-amber); color: #2a1a14;
  padding: 0.4rem 0.8rem; border-radius: var(--radius-full);
  font-size: 0.95rem;
  box-shadow: var(--shadow-soft);
}
.chip-a { top: 12%; left: -2%; transform: rotate(-8deg); }
.chip-b { top: 38%; right: -4%; background: var(--color-accent); color: #fff; transform: rotate(6deg); }
.float-sticker { position: absolute; width: 96px; height: auto; filter: drop-shadow(0 10px 16px rgba(42,26,20,0.22)); }
.sticker-coin { bottom: -6%; left: -4%; transform: rotate(-12deg); width: 104px; }
.sticker-hiking { top: -7%; right: 4%; width: 88px; transform: rotate(10deg); }

/* ── How it works ── */
.how { padding-block: clamp(3.5rem, 8vw, 6rem); }
.steps {
  display: grid; gap: 1.25rem;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
}
.step-card {
  position: relative;
  display: flex; flex-direction: column; align-items: flex-start; gap: 0.5rem;
  padding: 2.25rem 1.5rem 1.6rem;
  background: var(--color-bg-card);
  border: 1px solid var(--color-border-card);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-card);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}
.step-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-soft); }
.step-num {
  position: absolute; top: -16px; left: 1.5rem;
  width: 38px; height: 38px;
  display: grid; place-items: center;
  border-radius: 50%;
  background: var(--color-accent); color: #fff;
  font-family: var(--font-display); font-weight: 600; font-size: 1.15rem;
  box-shadow: 0 4px 0 var(--color-accent-dark);
}
.step-sticker { height: 84px; width: auto; margin: 0.4rem 0 0.3rem; }
.step-title { font-size: 1.2rem; font-weight: 600; color: var(--color-ink); }
.step-desc { font-size: 0.95rem; color: var(--color-ink-muted); line-height: 1.55; }

/* ── Spotlights ── */
.spotlight { padding-block: clamp(3.5rem, 8vw, 6rem); }
.spotlight-mint { background: var(--color-mint-pale); }
.spotlight-amber { background: var(--color-amber-pale); }
.spotlight-inner {
  display: grid; grid-template-columns: 1fr; gap: 2.5rem; align-items: center;
}
@media (min-width: 820px) {
  .spotlight-inner { grid-template-columns: 0.9fr 1.1fr; gap: 3.5rem; }
  .spotlight-reverse .spotlight-art { order: 2; }
}
.spotlight-art { display: flex; justify-content: center; }
.spotlight-art .phone { max-width: 280px; transform: rotate(-2deg); }
