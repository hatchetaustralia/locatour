{
  "expo": {
    "name": "Locatour",
    "slug": "locatour",
    "owner": "hatchet_agency-org",
    "extra": {
      "eas": {
        "projectId": "df417321-c3f6-409d-8232-019491d948c4"
      }
    },
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "fingerprint"
    },
    "updates": {
      "url": "https://u.expo.dev/df417321-c3f6-409d-8232-019491d948c4"
    },
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "locatour",
    "userInterfaceStyle": "light",
    "ios": {
      "bundleIdentifier": "com.hatchet.locatour",
      "icon": "./assets/images/icon.png"
    },
    "android": {
      "package": "com.hatchet.locatour",
      "adaptiveIcon": {
        "backgroundColor": "#FCF0E8",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyAk_DFHT4st9R3wN8XXPX8LMWzQY68HrS8"
        }
      }
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "./plugins/with-android-abis",
        "arm64-v8a"
      ],
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-sqlite",
      [
        "expo-camera",
        {
          "cameraPermission": "Locatour needs camera access so you can take a photo to check in at a location.",
          "recordAudioAndroid": false
        }
      ],
      [
        "expo-location",
        {
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true,
          "locationWhenInUsePermission": "Locatour uses your location to verify you are at a check-in spot.",
          "locationAlwaysAndWhenInUsePermission": "Locatour watches for nearby spots in the background so it can nudge you when you're close to one — even hidden ones.",
          "locationAlwaysPermission": "Locatour watches for nearby spots in the background so it can nudge you when you're close to one — even hidden ones."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#7C5CFF",
          "defaultChannel": "geofence-alerts"
        }
      ],
      "expo-image",
      "@react-native-google-signin/google-signin"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
