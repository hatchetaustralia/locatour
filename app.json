{
  "expo": {
    "name": "Locatour",
    "slug": "locatour",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "locatour",
    "userInterfaceStyle": "light",
    "ios": {
      "bundleIdentifier": "com.hatchet.locatour",
      "icon": "./assets/expo.icon"
    },
    "android": {
      "package": "com.hatchet.locatour",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyAxZenbi9VemfeQysjl_qfm5QEL1xVwQog"
        }
      }
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-sqlite",
      [
        "expo-camera",
        {
          "cameraPermission": "Locatour needs camera access so you can take a photo to check in at a location.",
          "recordAudioAndroid": false
        }
      ],
      [
        "expo-location",
        {
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true,
          "locationWhenInUsePermission": "Locatour uses your location to verify you are at a check-in spot.",
          "locationAlwaysAndWhenInUsePermission": "Locatour watches for nearby spots in the background so it can nudge you when you're close to one — even hidden ones.",
          "locationAlwaysPermission": "Locatour watches for nearby spots in the background so it can nudge you when you're close to one — even hidden ones."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#7C5CFF",
          "defaultChannel": "geofence-alerts"
        }
      ],
      "expo-image"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
